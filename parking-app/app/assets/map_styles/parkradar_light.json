{
  "version": 8,
  "id": "parkradar-light",
  "name": "ParkRadar Jour",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": ["https://tiles.openfreemap.org/planet/{z}/{x}/{y}.pbf"],
      "minzoom": 1,
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#FAF7F2" }
    },
    {
      "id": "landcover-green",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["all", ["==", "$type", "Polygon"], ["in", "class", "grass", "wood"]],
      "paint": { "fill-color": "#D9EBD7", "fill-opacity": 0.8 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#CDE8CE" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#A8CBEA" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "minzoom": 10,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#A8CBEA",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 10, 0.6, 14, 1.6, 18, 5]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 14,
      "paint": { "fill-color": "#EFEAE2" }
    },
    {
      "id": "road-tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["==", "brunnel", "tunnel"], ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary", "minor"]],
      "layout": { "line-cap": "butt", "line-join": "round" },
      "paint": {
        "line-color": "#EAE4DA",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 1, 14, 4.5, 18, 20]
      }
    },
    {
      "id": "road-service-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 15,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["any", ["==", "class", "service"], ["all", ["==", "class", "path"], ["==", "subclass", "pedestrian"]]]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#DED8CE",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 15, 2.6, 18, 11]
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["==", "class", "minor"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D8D2C8",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 13, 2.2, 15, 6, 18, 22]
      }
    },
    {
      "id": "road-medium-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 11,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["in", "class", "secondary", "tertiary"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#D8D2C8",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 11, 1.6, 13, 3.4, 15, 7.5, 18, 24]
      }
    },
    {
      "id": "road-major-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["in", "class", "trunk", "primary"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#E4D6AE",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 2, 13, 4.2, 15, 8.5, 18, 26]
      }
    },
    {
      "id": "road-motorway-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["==", "class", "motorway"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#E4D6AE",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 2.6, 13, 5, 15, 9.5, 18, 28]
      }
    },
    {
      "id": "road-service",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 15,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["any", ["==", "class", "service"], ["all", ["==", "class", "path"], ["==", "subclass", "pedestrian"]]]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 15, 1.5, 18, 9]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 13,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["==", "class", "minor"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 13, 1.2, 15, 4.2, 18, 19]
      }
    },
    {
      "id": "road-medium",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 11,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["in", "class", "secondary", "tertiary"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 11, 0.9, 13, 2.2, 15, 5.4, 18, 20.5]
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["in", "class", "trunk", "primary"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFF3D6",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 1.2, 13, 2.8, 15, 6.2, 18, 22.5]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 10,
      "filter": ["all", ["!in", "brunnel", "tunnel"], ["==", "class", "motorway"]],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FFEDC2",
        "line-width": ["interpolate", ["exponential", 1.6], ["zoom"], 10, 1.7, 13, 3.6, 15, 7, 18, 24.5]
      }
    },
    {
      "id": "label-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10,
      "maxzoom": 16,
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:fr"], ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Roboto"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 15, 15, 21],
        "text-max-width": 8,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#3C4451",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "label-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 10,
      "maxzoom": 15,
      "filter": ["==", "class", "town"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:fr"], ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Roboto"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 12, 14, 15],
        "text-max-width": 8,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#4A5260",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "label-neighbourhood",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 12,
      "maxzoom": 17,
      "filter": ["in", "class", "suburb", "quarter", "neighbourhood", "village"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:fr"], ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Roboto"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 11, 16, 13.5],
        "text-max-width": 8,
        "text-anchor": "center"
      },
      "paint": {
        "text-color": "#7D8595",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-road-major",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 14,
      "filter": ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:fr"], ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Roboto"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 11.5, 18, 14.5],
        "text-rotation-alignment": "auto"
      },
      "paint": {
        "text-color": "#5B6472",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "label-road-minor",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 15,
      "filter": ["==", "class", "minor"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:fr"], ["get", "name:latin"], ["get", "name"]],
        "text-font": ["Roboto"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 11, 18, 14],
        "text-rotation-alignment": "auto"
      },
      "paint": {
        "text-color": "#5B6472",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.2
      }
    }
  ]
}
